#!/bin/sh -e

GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SYSTEM=$(uname -m)

case "$SYSTEM" in
    x86_64)
        FLAKE_TARGET="x86_64-linux"
        ;;
    aarch64)
        FLAKE_TARGET="aarch64-linux"
        ;;
    *)
        echo "${RED}Unsupported architecture: $SYSTEM${NC}"
        exit 1
        ;;
esac

# Detect the skip-worktree / assume-unchanged trap: if user-info.nix has been
# edited on disk but git reports the whole tree as clean, Nix builds with the
# HEAD version and silently ignores the edits.
if [ -f user-info.nix ] && git diff --quiet HEAD -- 2>/dev/null; then
    disk_hash=$(git hash-object user-info.nix 2>/dev/null || echo "")
    head_hash=$(git rev-parse HEAD:user-info.nix 2>/dev/null || echo "")
    if [ -n "$head_hash" ] && [ "$disk_hash" != "$head_hash" ]; then
        echo "${RED}ERROR: user-info.nix on disk differs from HEAD, but git"
        echo "reports the working tree as clean (likely skip-worktree or"
        echo "assume-unchanged is set). Nix would build with the HEAD version"
        echo "and silently ignore your edits.${NC}"
        echo ""
        echo "${YELLOW}Fix — toggle the bit off, re-run, then toggle back on:${NC}"
        echo "  git update-index --no-skip-worktree user-info.nix"
        echo "  nix run .#build-switch"
        echo "  git update-index --skip-worktree user-info.nix"
        exit 1
    fi
fi

is_nix_os() {
    [ -e /etc/NIXOS ] && return 0

    return 1
}

echo "${YELLOW}Starting...${NC}"

if is_nix_os; then
    echo "Running on a NixOS-based system"
    /run/current-system/sw/bin/nixos-rebuild switch --flake .#$FLAKE_TARGET $@
else
    echo "Running on a Linux system (non-NixOS)"
    home-manager switch --flake .#$FLAKE_TARGET $@
fi

echo "${GREEN}Switch to new generation complete!${NC}"
