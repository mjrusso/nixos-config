#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: vm <subcommand> [args]

Subcommands:
  start <name>            Start a VM, creating its disk from the golden
                          image if needed. Alias: up.
  stop <name>             Stop the VM, preserving disk/state. Alias: halt.
  restart <name>          Stop and start the VM.
  grow <name> [amount]    Increase the VM disk by amount, default 10G.
                          The VM must be stopped.
  wipe <name>             Stop the VM and remove disk/boot state, preserving
                          its name and allocated SSH port.
  destroy <name>          Stop and delete the VM and all its state. Alias: rm.
  ssh <name> [args...]    SSH into the VM.
  switch <name> [nixos-rebuild args...]
        Apply this repo's switchable VM NixOS config to the running VM
        over root SSH. Supported on Linux hosts only.
  console <name>          Stream the VM's serial log (follows live boot
                          output; Ctrl-C detaches without touching the VM).
  info <name>             Print connection info (ssh/console/ports)
                          for an existing VM.
  list                    List known VMs and their status. Alias: ls.

  publish <name> <guest-port> [<host-port>] [--bind <addr>] [--auto]
        Forward a guest port to the host. Defaults: host-port = guest-port,
        bind = 0.0.0.0 (reachable from other hosts on the LAN). Pass
        --bind 127.0.0.1 for loopback-only. Pass --auto to let the host
        pick a free port (30000-60000); the picked port is printed on
        stdout so `port=$(vm publish ...)` works for scripting.
  unpublish <name> <host-port> [--bind <addr>]
        Remove a previously-added forward.
  ports <name>            List all active port forwards for a VM.

  share <name> <tag> <host-path> <guest-path> [--readonly]
        Persistently expose a host directory to the guest via virtiofs.
        The VM must be restarted before new share declarations take effect.
  unshare <name> <tag>    Remove a persisted virtiofs share declaration.
  shares <name>           List persisted virtiofs share declarations.

State directory: $VMS_DIR (default: ~/vms). Golden images and their
`.meta.json` sidecars are expected there — bake them from the
nixos-config repo:

  ./scripts/bake-golden

Networking:
  A per-VM gvproxy instance provides user-mode networking for both
  qemu (Linux) and vfkit (Darwin), unifying the two drivers. SSH is
  exposed on the allocated port (2222-2299), bound 0.0.0.0 so the
  VM is reachable from other hosts. Additional forwards are managed
  through gvproxy's HTTP API from the host via `vm publish`/`vm
  unpublish`.

Host directory sharing:
  Host directories are declared with `vm share` and persisted in the
  VM state directory. Shares are attached at VM start, so adding or
  removing shares for a running VM requires a restart.
USAGE
}

VMS_DIR="${VMS_DIR:-$HOME/vms}"
# Sanity-check VMS_DIR before anything in this script does `rm -rf` under it.
if [ -z "$VMS_DIR" ] || [ "$VMS_DIR" = "/" ]; then
  echo "Refusing to operate with VMS_DIR='$VMS_DIR'." >&2
  exit 1
fi
# Reject whitespace and shell metacharacters in VMS_DIR. The only
# *load-bearing* character is "'" — acquire_launch_lock installs an EXIT
# trap whose body embeds $d (= $VMS_DIR/$name) inside single quotes,
# and a stray "'" there would break out of the quoting and inject
# shell. The rest are hygiene (whitespace breaks unquoted expansions
# elsewhere in the script; the remaining metacharacters are
# belt-and-suspenders against future refactors that might drop the
# single quotes around $d). validate_name further restricts $name to
# [a-zA-Z0-9_-]; both halves of $d have to stay clean.
case "$VMS_DIR" in
  *"'"*|*[$' \t\n\r"`$\\;&|<>(){}*?!#~']*)
    echo "Refusing to operate with VMS_DIR containing whitespace or shell metacharacters: '$VMS_DIR'." >&2
    exit 1
    ;;
esac
PORT_LOW=2222
PORT_HIGH=2299

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "Missing required command: $1" >&2; exit 1; }
}

require_arg_count() {
  local usage="$1" expected="$2"
  shift 2
  [ "$#" -eq "$expected" ] || { echo "Usage: $usage" >&2; exit 1; }
}

external_host_hint() {
  local host=""
  host="$(hostname -f 2>/dev/null || true)"
  if [ -z "$host" ]; then
    host="$(hostname 2>/dev/null || true)"
  fi
  if [ -n "$host" ]; then
    echo "$host"
  else
    echo "HOST"
  fi
}

# Copy an image file preserving sparseness. Darwin's BSD cp has no
# sparse detection, so a cp of a (potentially sparse) raw image fully
# allocates the destination — which means every `vm start` would balloon
# ~/vms by the full logical disk size. `cp -c` uses clonefile(2) for
# an instant CoW clone when source and destination are on the same
# APFS volume, which is both faster and disk-space-free. Fall back to
# plain cp when clonefile isn't possible (cross-volume, non-APFS) or
# on Linux, where GNU cp's default --sparse=auto handles it.
copy_image() {
  local src="$1" dst="$2"
  if [ "$(uname -s)" = "Darwin" ] && cp -c "$src" "$dst" 2>/dev/null; then
    return 0
  fi
  cp "$src" "$dst"
}

meta_for_golden() {
  echo "$1.meta.json"
}

ssh_user() {
  # $1: a VM's state directory. Read the username from its meta.json
  # sidecar, snapshotted at `start` time and pinned to the golden the VM
  # was actually installed from, so later rebakes don't produce
  # mismatches.
  #
  # Typically called via command substitution, so use `return` instead
  # of `exit` — callers should check the exit status (via `|| exit`).
  command -v jq >/dev/null 2>&1 || { echo "Missing required command: jq" >&2; return 1; }
  local meta="$1/meta.json"
  [ -f "$meta" ] || {
    echo "Missing meta sidecar: $meta" >&2
    echo "Run ./scripts/bake-golden from the nixos-config repo." >&2
    return 1
  }
  jq -r '.user' "$meta"
}

host_image_system() {
  case "$(uname -s)" in
    Linux)
      case "$(uname -m)" in
        x86_64) echo "x86_64-linux" ;;
        aarch64) echo "aarch64-linux" ;;
        *) echo "Unsupported host architecture: $(uname -m)" >&2; return 1 ;;
      esac
      ;;
    Darwin)
      # vfkit runs Linux guests natively on the host arch.
      case "$(uname -m)" in
        arm64|aarch64) echo "aarch64-linux" ;;
        x86_64) echo "x86_64-linux" ;;
        *) echo "Unsupported host architecture: $(uname -m)" >&2; return 1 ;;
      esac
      ;;
    *) echo "Unsupported host OS: $(uname -s)" >&2; return 1 ;;
  esac
}

host_image_format() {
  case "$(uname -s)" in
    Darwin) echo "raw" ;;     # vfkit uses raw disks
    *)      echo "qcow2" ;;   # qemu uses qcow2
  esac
}

# UEFI firmware is required for aarch64 qemu boots. The Nix wrapper
# pins VM_QEMU_AARCH64_UEFI to a known-good store path; fall back to
# standard system-package locations for non-Nix hosts.
find_aarch64_uefi() {
  if [ -n "${VM_QEMU_AARCH64_UEFI:-}" ] && [ -f "$VM_QEMU_AARCH64_UEFI" ]; then
    echo "$VM_QEMU_AARCH64_UEFI"
    return 0
  fi
  local p
  for p in \
      /usr/share/AAVMF/AAVMF_CODE.fd \
      /usr/share/qemu/edk2-aarch64-code.fd \
      /usr/share/edk2/aarch64/QEMU_EFI.fd; do
    if [ -f "$p" ]; then
      echo "$p"
      return 0
    fi
  done
  return 1
}

golden_image_path() {
  local system format
  system="$(host_image_system)" || return 1
  format="$(host_image_format)"
  echo "$VMS_DIR/golden-$system.$format"
}

ensure_golden() {
  local golden; golden="$(golden_image_path)"
  if [ ! -f "$golden" ]; then
    cat >&2 <<EOF
Golden image not found: $golden

Bake it from the nixos-config repo:
  ./scripts/bake-golden

EOF
    exit 1
  fi
  if [ ! -f "$(meta_for_golden "$golden")" ]; then
    cat >&2 <<EOF
Golden image metadata not found: $(meta_for_golden "$golden")

Bake it from the nixos-config repo:
  ./scripts/bake-golden

EOF
    exit 1
  fi
  echo "$golden"
}

disk_path_for() {
  echo "$1/disk.$(host_image_format)"
}

existing_disk_path_for() {
  local d="$1"
  local expected; expected="$(disk_path_for "$d")"
  if [ -f "$expected" ]; then
    echo "$expected"
    return 0
  fi

  local found="" p
  for p in "$d/disk.qcow2" "$d/disk.raw"; do
    [ -f "$p" ] || continue
    if [ -n "$found" ]; then
      echo "Multiple VM disks found under $d; refusing to choose one." >&2
      return 1
    fi
    found="$p"
  done

  if [ -n "$found" ]; then
    echo "$found"
    return 0
  fi

  echo "No VM disk found under $d. Run 'vm start $(basename "$d")' first." >&2
  return 1
}

metadata_disk_path_for() {
  echo "$1/metadata.raw"
}

shares_path_for() {
  echo "$1/shares.json"
}

validate_share_tag() {
  local tag="$1"
  [[ "$tag" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || {
    echo "Invalid share tag '$tag' (allowed: alphanumeric, '.', '_', '-'; must start with alphanumeric)." >&2
    return 1
  }
}

validate_guest_path() {
  local path="$1"
  case "$path" in
    /*) ;;
    *) echo "Guest path must be absolute: $path" >&2; return 1 ;;
  esac
  case "$path" in
    *"'"*|*$'\t'*|*$'\n'*|*$'\r'*)
      echo "Guest path must not contain single quotes, tabs, or newlines: $path" >&2
      return 1
      ;;
  esac
}

validate_host_path() {
  local path="$1"
  [ -d "$path" ] || {
    echo "Host path is not a directory: $path" >&2
    return 1
  }
  case "$path" in
    *,*|*$'\t'*|*$'\n'*|*$'\r'*)
      echo "Host path must not contain commas, tabs, or newlines: $path" >&2
      return 1
      ;;
  esac
}

canonical_host_path() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
  else
    local dir base
    dir="$(cd "$(dirname "$path")" && pwd -P)"
    base="$(basename "$path")"
    printf '%s/%s\n' "$dir" "$base"
  fi
}

ensure_shares_file() {
  local d="$1" shares
  shares="$(shares_path_for "$d")"
  if [ ! -f "$shares" ]; then
    printf '[]\n' > "$shares"
  fi
}

validate_shares_file() {
  local d="$1" shares
  shares="$(shares_path_for "$d")"
  [ -f "$shares" ] || return 0
  command -v jq >/dev/null 2>&1 || { echo "Missing required command: jq" >&2; return 1; }
  jq -e '
    type == "array"
    and all(.[]; (
      type == "object"
      and (.tag | type == "string")
      and (.hostPath | type == "string")
      and (.guestPath | type == "string")
      and (.readonly | type == "boolean")
    ))
    and ((map(.tag) | unique | length) == length)
  ' "$shares" >/dev/null || {
    echo "Invalid shares file: $shares" >&2
    return 1
  }

  local tag host_path guest_path
  while IFS=$'\t' read -r tag host_path guest_path; do
    [ -n "$tag" ] || continue
    validate_share_tag "$tag" || return 1
    case "$host_path" in
      *,*|*$'\t'*|*$'\n'*|*$'\r'*)
        echo "Host path must not contain commas, tabs, or newlines: $host_path" >&2
        return 1
        ;;
    esac
    validate_guest_path "$guest_path" || return 1
  done < <(jq -r '.[] | [.tag, .hostPath, .guestPath] | @tsv' "$shares")
}

validate_share_paths_for_start() {
  local d="$1" shares
  shares="$(shares_path_for "$d")"
  [ -f "$shares" ] || return 0
  local tag host_path
  while IFS=$'\t' read -r tag host_path; do
    [ -n "$tag" ] || continue
    validate_host_path "$host_path" || return 1
  done < <(jq -r '.[] | [.tag, .hostPath] | @tsv' "$shares")
}

shares_count() {
  local d="$1" shares
  shares="$(shares_path_for "$d")"
  [ -f "$shares" ] || { echo 0; return 0; }
  jq 'length' "$shares"
}

hostname_for_vm() {
  local name="$1"
  local vm_host host
  vm_host="$(hostname -s 2>/dev/null || true)"
  if [ -z "$vm_host" ]; then
    vm_host="$(hostname 2>/dev/null || true)"
  fi
  vm_host="${vm_host%%.*}"

  if [ -n "$vm_host" ]; then
    host="$vm_host-$name"
  else
    host="$name"
  fi
  host="${host//_/-}"
  host="${host,,}"
  host="$(printf '%s' "$host" | sed -E 's/[^a-z0-9-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  host="${host:0:63}"
  host="$(printf '%s' "$host" | sed -E 's/-+$//')"
  if [ -z "$host" ]; then
    echo "Invalid VM hostname derived from '$name'." >&2
    return 1
  fi
  echo "$host"
}

write_metadata_disk() {
  local d="$1" name="$2"
  local metadata; metadata="$(metadata_disk_path_for "$d")"
  local hostname; hostname="$(hostname_for_vm "$name")" || return 1
  local payload="$d/metadata.txt"

  {
    echo "MJRVMMETA1"
    echo "hostname=$hostname"
    echo "name=$name"
    local shares; shares="$(shares_path_for "$d")"
    if [ -f "$shares" ]; then
      jq -r '.[] | "share=\(.tag)\t\(.guestPath)\t\(.readonly)"' "$shares"
    fi
  } > "$payload"

  rm -f "$metadata.partial"
  dd if=/dev/zero of="$metadata.partial" bs=1048576 count=1 2>/dev/null
  dd if="$payload" of="$metadata.partial" conv=notrunc 2>/dev/null
  mv "$metadata.partial" "$metadata"
}

ssh_host_for() {
  # SSH is always reached via localhost from the VM host. start_gvproxy
  # rebinds the SSH forward to all interfaces (0.0.0.0) so other hosts
  # can also reach it at <vm-host-ip>:$port.
  echo "localhost"
}

vm_mac() {
  # Deterministic MAC from VM name. Locally-administered OUI (02:*) so
  # there's no collision risk with real hardware.
  local name="$1" h
  if command -v md5sum >/dev/null 2>&1; then
    h="$(printf '%s' "$name" | md5sum | cut -c1-10)"
  else
    # Darwin has md5 (different CLI) instead of md5sum.
    h="$(printf '%s' "$name" | md5 -q | cut -c1-10)"
  fi
  printf '02:%s:%s:%s:%s:%s\n' "${h:0:2}" "${h:2:2}" "${h:4:2}" "${h:6:2}" "${h:8:2}"
}

try_vfkit_graceful_shutdown() {
  local sock="$1"
  [ -S "$sock" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl --unix-socket "$sock" -X PUT \
       -H "Content-Type: application/json" \
       -d '{"state":"Stop"}' \
       --max-time 2 --silent --output /dev/null \
       "http://_/vm/state" >/dev/null 2>&1
}

validate_name() {
  local name="$1"
  [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]] || {
    echo "Invalid VM name '$name' (allowed: alphanumeric, '_', '-'; must not start with '-' or '_')." >&2
    exit 1
  }
}

vm_dir() { echo "$VMS_DIR/$1"; }

ssh_opts() {
  echo "-o StrictHostKeyChecking=no \
-o UserKnownHostsFile=/dev/null \
-o GlobalKnownHostsFile=/dev/null \
-o LogLevel=ERROR"
}

ssh_quick_opts() {
  echo "$(ssh_opts) \
-o ConnectTimeout=1 \
-o ConnectionAttempts=1"
}

port_in_use() {
  ss -tlnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${1}\$"
}

allocate_port() {
  for port in $(seq "$PORT_LOW" "$PORT_HIGH"); do
    if ! port_in_use "$port"; then
      echo "$port"; return 0
    fi
  done
  echo "No free port in ${PORT_LOW}-${PORT_HIGH}" >&2
  exit 1
}

# Like allocate_port but scans a wider ephemeral-friendly range. Used
# by `vm publish --auto` when the caller doesn't care which host port
# they get. Starts at a random offset so concurrent --auto callers
# don't all collide on the same first candidate.
allocate_free_port() {
  local lo=30000 hi=60000
  local span=$((hi - lo + 1))
  local start=$(( lo + (RANDOM % span) ))
  local port
  local i
  for i in $(seq 0 $((span - 1))); do
    port=$(( lo + ((start - lo + i) % span) ))
    if ! port_in_use "$port"; then
      echo "$port"; return 0
    fi
  done
  echo "No free port in $lo-$hi" >&2
  return 1
}

is_running() {
  local pidfile="$1"
  [ -f "$pidfile" ] || return 1
  local pid; pid="$(cat "$pidfile")"
  kill -0 "$pid" 2>/dev/null || return 1
  # Guard against PID reuse: check the live pid's command name matches one of
  # the drivers we know how to start. Prefer /proc/<pid>/cmdline's argv[0] over
  # /proc/<pid>/comm: comm is capped at TASK_COMM_LEN (15 chars) and reflects
  # the *exec'd* binary's name, which on NixOS is e.g.
  # `.qemu-system-x86_64-wrapped` (truncates to `.qemu-system-x8`, which fails
  # the qemu-system* match). NixOS's makeWrapper sets argv[0] to the unwrapped
  # name, so cmdline gives us `qemu-system-x86_64`.
  local comm
  if [ -r "/proc/$pid/cmdline" ]; then
    comm="$(tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | head -n1)" || return 1
    comm="${comm##*/}"
  else
    comm="$(ps -o comm= -p "$pid" 2>/dev/null)" || return 1
    comm="${comm##*/}"
  fi
  [[ "$comm" == qemu-system* ]] || [[ "$comm" == vfkit* ]]
}

try_graceful_shutdown() {
  local socket="$1"
  [ -S "$socket" ] || return 1
  command -v socat >/dev/null 2>&1 || return 1
  echo "system_powerdown" | socat - "UNIX-CONNECT:$socket" >/dev/null 2>&1
}

# gvproxy provides user-mode networking for both qemu and vfkit via a
# unix socket, unifying what were previously two divergent NAT paths
# (hostfwd vs. vmnet+dhcpd_leases). Each VM runs its own gvproxy
# process with its own socket triple:
#   - $d/network.sock     host-side HTTP forwarder API (`vm publish` etc.)
#   - $d/qemu-net.sock    qemu's -netdev stream endpoint (Linux)
#   - $d/vfkit-net.sock   vfkit's virtio-net unixSocketPath (Darwin)
# The forwarder API is host-side only (on $d/network.sock). gvproxy's
# -services flag creates another host listener, not a virtual-network
# one, so guest-initiated forwarding via that path is not available —
# use `vm publish` from the host.

# gvproxy's default virtual network reserves .1 (gateway) and .2
# (host.containers.internal). The first DHCP client gets .3, and
# since each VM runs its own gvproxy instance with its own fresh
# network, the sole guest always lands at .3. `vm publish` hard-codes
# it as the forward target.
GVPROXY_GUEST=192.168.127.3

# Resolve the gvproxy binary: pinned by the Nix wrapper via VM_GVPROXY,
# falling back to $PATH for non-Nix hosts.
gvproxy_bin() {
  if [ -n "${VM_GVPROXY:-}" ] && [ -x "$VM_GVPROXY" ]; then
    echo "$VM_GVPROXY"
    return 0
  fi
  command -v gvproxy 2>/dev/null && return 0
  echo "Missing required command: gvproxy (pin via VM_GVPROXY or add to PATH)" >&2
  return 1
}

is_gvproxy_running() {
  local pidfile="$1"
  [ -f "$pidfile" ] || return 1
  local pid; pid="$(cat "$pidfile")"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  # Same PID-reuse guard as is_running. gvproxy's NixOS wrap exposes
  # argv[0] as "gvproxy" via makeWrapper; comm would be truncated to
  # `.gvproxy-wrapped` which this accepts too.
  local comm
  if [ -r "/proc/$pid/cmdline" ]; then
    comm="$(tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | head -n1)" || return 1
    comm="${comm##*/}"
  else
    comm="$(ps -o comm= -p "$pid" 2>/dev/null)" || return 1
    comm="${comm##*/}"
  fi
  [[ "$comm" == gvproxy* ]] || [[ "$comm" == .gvproxy* ]]
}

# Launch gvproxy for a VM. Returns once the VM-side socket is ready
# for the driver to connect to; fails fast if gvproxy dies early.
# Also rebinds the SSH forward from 127.0.0.1 to 0.0.0.0 so other
# hosts can reach the VM — otherwise the only way in is from the
# VM host itself.
start_gvproxy() {
  local d="$1" driver="$2" port="$3"
  local bin; bin="$(gvproxy_bin)" || return 1

  local vm_sock vm_flag
  case "$driver" in
    qemu)  vm_sock="$d/qemu-net.sock";  vm_flag="-listen-qemu"  ;;
    vfkit) vm_sock="$d/vfkit-net.sock"; vm_flag="-listen-vfkit" ;;
    *) echo "Unknown driver for gvproxy: $driver" >&2; return 1 ;;
  esac

  rm -f "$d/network.sock" "$vm_sock" "$d/gvproxy.pid"

  # -ssh-port: gvproxy installs a built-in 127.0.0.1:$port → guest:22 forward.
  #            The flag is required to pick a unique port per VM; we then
  #            immediately swap that forward's bind to 0.0.0.0 (see below).
  # -pid-file: written asynchronously after startup and used by stop_gvproxy.
  # Socket endpoints need the `unix://` scheme prefix — `-listen-qemu`
  # and `-listen-vfkit` parse their argument as a URL and reject bare
  # paths with "unexpected scheme".
  local gvproxy_args=(
    -listen "unix://$d/network.sock"
    "$vm_flag" "unix://$vm_sock"
    -ssh-port "$port"
    -pid-file "$d/gvproxy.pid"
  )
  if command -v setsid >/dev/null 2>&1; then
    setsid -f "$bin" "${gvproxy_args[@]}" > "$d/gvproxy.log" 2>&1 < /dev/null
  else
    nohup "$bin" "${gvproxy_args[@]}" > "$d/gvproxy.log" 2>&1 < /dev/null &
    local pid=$!
    disown "$pid" 2>/dev/null || true
    echo "$pid" > "$d/gvproxy.pid"
  fi

  # Wait up to ~5s for gvproxy to create its sockets and pidfile. If
  # it dies before that, surface the log and give up.
  local ready=0
  for _ in $(seq 1 50); do
    if [ -s "$d/gvproxy.pid" ] && { [ -S "$vm_sock" ] || [ -e "$vm_sock" ]; } && [ -S "$d/network.sock" ]; then
      ready=1; break
    fi
    if [ -s "$d/gvproxy.pid" ] && ! is_gvproxy_running "$d/gvproxy.pid"; then
      echo "gvproxy exited before its VM socket appeared. See $d/gvproxy.log." >&2
      rm -f "$d/gvproxy.pid"
      return 1
    fi
    sleep 0.1
  done
  if [ "$ready" -ne 1 ]; then
    echo "Timed out waiting for gvproxy's VM socket at $vm_sock." >&2
    if [ -s "$d/gvproxy.pid" ]; then
      local pid; pid="$(cat "$d/gvproxy.pid")"
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$d/gvproxy.pid"
    return 1
  fi

  # Swap the loopback SSH forward for an all-interfaces one. gvproxy's
  # -ssh-port flag binds 127.0.0.1:$port, which means SSH only works
  # from the VM host itself — but `vm` is the only way to manage VMs,
  # so a loopback-only SSH leaves no path in from other hosts. The
  # forwarder API treats the -ssh-port entry as a normal rule we can
  # remove and replace.
  if ! forwarder_unexpose "$d" "127.0.0.1:$port" >/dev/null 2>&1; then
    echo "Warning: could not remove gvproxy's built-in SSH forward." >&2
  fi
  if ! forwarder_expose "$d" ":$port" "$GVPROXY_GUEST:22" >/dev/null; then
    echo "Warning: could not add 0.0.0.0 SSH forward; SSH may only be reachable via loopback." >&2
  fi

  return 0
}

stop_gvproxy() {
  local d="$1"
  if is_gvproxy_running "$d/gvproxy.pid"; then
    local pid; pid="$(cat "$d/gvproxy.pid")"
    kill "$pid" 2>/dev/null || true
    for _ in $(seq 1 20); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.5
    done
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$d/gvproxy.pid" "$d/network.sock" "$d/qemu-net.sock" "$d/vfkit-net.sock"
}

virtiofsd_bin() {
  if [ -n "${VM_VIRTIOFSD:-}" ] && [ -x "$VM_VIRTIOFSD" ]; then
    echo "$VM_VIRTIOFSD"
    return 0
  fi
  command -v virtiofsd 2>/dev/null && return 0
  echo "Missing required command: virtiofsd (pin via VM_VIRTIOFSD or add to PATH)" >&2
  return 1
}

start_virtiofsd() {
  local d="$1" tag="$2" host_path="$3" readonly="$4"
  local bin; bin="$(virtiofsd_bin)" || return 1
  local sock="$d/virtiofs-$tag.sock"
  local pidfile="$d/virtiofs-$tag.pid"
  local log="$d/virtiofs-$tag.log"
  local args=(
    --shared-dir "$host_path"
    --socket-path "$sock"
    --cache auto
    # Running as a regular user in this script's launch model needs the
    # relaxed sandbox/seccomp mode; otherwise file operations can hang on
    # the tested NixOS/QEMU stack.
    --sandbox none
    --seccomp none
    --inode-file-handles=never
  )
  if [ "$readonly" = "true" ]; then
    args+=(--readonly)
  fi

  rm -f "$sock" "$pidfile"
  nohup "$bin" "${args[@]}" > "$log" 2>&1 < /dev/null &
  local pid=$!
  disown "$pid" 2>/dev/null || true
  echo "$pid" > "$pidfile"

  local ready=0
  for _ in $(seq 1 50); do
    if [ -S "$sock" ]; then
      ready=1
      break
    fi
    if [ -s "$pidfile" ]; then
      local pid; pid="$(cat "$pidfile")"
      if ! kill -0 "$pid" 2>/dev/null; then
        echo "virtiofsd for share '$tag' exited before its socket appeared. See $log." >&2
        rm -f "$pidfile"
        return 1
      fi
    fi
    sleep 0.1
  done

  if [ "$ready" -ne 1 ]; then
    echo "Timed out waiting for virtiofsd socket at $sock." >&2
    [ -s "$pidfile" ] && kill "$(cat "$pidfile")" 2>/dev/null || true
    rm -f "$pidfile"
    return 1
  fi
}

stop_virtiofsd() {
  local d="$1" pidfile pid
  for pidfile in "$d"/virtiofs-*.pid; do
    [ -f "$pidfile" ] || continue
    pid="$(cat "$pidfile")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      for _ in $(seq 1 20); do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.2
      done
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
  rm -f "$d"/virtiofs-*.pid "$d"/virtiofs-*.sock
}

stop_guest_share_mounter() {
  local d="$1"
  if [ -f "$d/share-mount.pid" ]; then
    kill "$(cat "$d/share-mount.pid")" 2>/dev/null || true
    rm -f "$d/share-mount.pid"
  fi
}

start_guest_share_mounter() {
  local d="$1" port="$2"
  local shares; shares="$(shares_path_for "$d")"
  [ -f "$shares" ] || return 0
  [ "$(jq 'length' "$shares")" = "0" ] && return 0

  local opts; opts="$(ssh_quick_opts)"
  (
    while [ ! -f "$d/share-mount.pid" ]; do
      sleep 0.05
    done
    trap 'rm -f "$d/share-mount.pid"' EXIT

    echo "Waiting for guest SSH on port $port..."
    local ready=0
    # shellcheck disable=SC2086
    for _ in $(seq 1 90); do
      if ssh -p "$port" $opts root@localhost true >/dev/null 2>&1; then
        echo "Guest SSH is ready; mounting shares..."
        ready=1
        break
      fi
      sleep 2
    done
    if [ "$ready" -ne 1 ]; then
      echo "Timed out waiting for guest SSH; shares were not mounted." >&2
      exit 1
    fi

    local tag guest_path share_readonly mount_opts script
    script="set -eu"
    while IFS=$'\t' read -r tag guest_path share_readonly; do
      [ -n "$tag" ] || continue
      mount_opts=""
      [ "$share_readonly" = "true" ] && mount_opts="-o ro"
      script="$script
mkdir -p '$guest_path'
nsenter --mount=/proc/1/ns/mnt -- mountpoint -q '$guest_path' || nsenter --mount=/proc/1/ns/mnt -- mount -t virtiofs $mount_opts '$tag' '$guest_path'"
    done < <(jq -r '.[] | [.tag, .guestPath, .readonly] | @tsv' "$shares")

    # Enter PID 1's mount namespace so the mount is usable from later SSH
    # sessions and normal system services, not only from this SSH session.
    # shellcheck disable=SC2086
    if ssh -p "$port" $opts root@localhost "$script"; then
      echo "Share mounting complete."
    else
      echo "Share mounting failed." >&2
      exit 1
    fi
  ) > "$d/share-mount.log" 2>&1 &
  local pid=$!
  disown "$pid" 2>/dev/null || true
  echo "$pid" > "$d/share-mount.pid"
}

try_guest_unmount_shares() {
  local d="$1" port="$2"
  local shares; shares="$(shares_path_for "$d")"
  [ -f "$shares" ] || return 1
  command -v jq >/dev/null 2>&1 || return 1
  [ "$(jq 'length' "$shares")" = "0" ] && return 1

  local opts; opts="$(ssh_quick_opts)"
  local guest_path script
  script="set +e"
  while IFS= read -r guest_path; do
    [ -n "$guest_path" ] || continue
    script="$script
nsenter --mount=/proc/1/ns/mnt -- mountpoint -q '$guest_path' && nsenter --mount=/proc/1/ns/mnt -- umount '$guest_path' || true"
  done < <(jq -r 'sort_by(.guestPath) | reverse | .[] | .guestPath' "$shares")

  # shellcheck disable=SC2086
  ssh -p "$port" $opts root@localhost "$script" >/dev/null 2>&1
}

# Thin wrappers over curl against gvproxy's HTTP forwarder API on
# $d/network.sock. The "http://_" host is a placeholder required by
# curl; the unix-socket carries the real connection.
forwarder_api() {
  # forwarder_api <vm-state-dir> <method> <path> [<json-body>]
  local d="$1" method="$2" path="$3" body="${4:-}"
  local sock="$d/network.sock"
  [ -S "$sock" ] || {
    echo "gvproxy control socket missing: $sock (is the VM running?)" >&2
    return 1
  }
  if [ -n "$body" ]; then
    curl --fail-with-body --silent --show-error \
      --unix-socket "$sock" \
      -X "$method" \
      -H 'Content-Type: application/json' \
      -d "$body" \
      "http://_$path"
  else
    curl --fail-with-body --silent --show-error \
      --unix-socket "$sock" \
      -X "$method" \
      "http://_$path"
  fi
}

forwarder_list()     { forwarder_api "$1" GET  /services/forwarder/all; }
forwarder_expose()   { forwarder_api "$1" POST /services/forwarder/expose   "{\"local\":\"$2\",\"remote\":\"$3\"}"; }
forwarder_unexpose() { forwarder_api "$1" POST /services/forwarder/unexpose "{\"local\":\"$2\"}"; }

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || {
    echo "Run 'vm switch' from within the nixos-config git repository." >&2
    return 1
  }
}

current_flake_rev() {
  local repo="$1"
  local rev
  rev="$(git -C "$repo" rev-parse HEAD 2>/dev/null || echo unknown)"
  if [ -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]; then
    rev="${rev}-dirty"
  fi
  echo "$rev"
}

record_switch_meta() {
  local d="$1" flake_target="$2" repo="$3"
  command -v jq >/dev/null 2>&1 || return 0
  [ -f "$d/meta.json" ] || return 0

  local switched_at flake_rev
  switched_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  flake_rev="$(current_flake_rev "$repo")"
  jq \
    --arg switched_at "$switched_at" \
    --arg switch_flake_rev "$flake_rev" \
    --arg switch_flake_target "$flake_target" \
    '. + {
      switched_at: $switched_at,
      switch_flake_rev: $switch_flake_rev,
      switch_flake_target: $switch_flake_target
    }' \
    "$d/meta.json" > "$d/meta.json.partial"
  mv "$d/meta.json.partial" "$d/meta.json"
}

# Acquire a per-VM launch lock at $d/.lock (a symlink whose target is
# the holder's pid). symlink(2) is atomic on both Linux and Darwin,
# which makes the create-and-record-holder step a single syscall — no
# window where a reader can see the lock without a holder. Auto-recovers
# if the holder pid is dead.
acquire_launch_lock() {
  local d="$1"
  while ! ln -s "$$" "$d/.lock" 2>/dev/null; do
    # Bail out if the state dir itself has vanished — a concurrent
    # `vm destroy` already inside its own lock can `rm -rf "$d"` out from
    # under us, at which point `ln -s` fails with ENOENT forever and
    # the loop would spin.
    [ -d "$d" ] || return 1
    local holder=""
    holder="$(readlink "$d/.lock" 2>/dev/null || true)"
    if [ -n "$holder" ] && kill -0 "$holder" 2>/dev/null; then
      echo "VM operation already in progress for $(basename "$d") (pid $holder)." >&2
      return 1
    fi
    # Re-check the target before unlinking, so a concurrent acquirer's
    # fresh lock (with a different target) isn't clobbered during our
    # TOCTOU window.
    local still=""
    still="$(readlink "$d/.lock" 2>/dev/null || true)"
    [ "$still" = "$holder" ] && rm -f "$d/.lock" 2>/dev/null || true
  done
  # This is the only EXIT trap in the script. Bash allows one handler
  # per signal, so adding another `trap ... EXIT` elsewhere would
  # silently replace this one and strand .lock files. If you need
  # another EXIT action, chain it here rather than installing a
  # second trap.
  # shellcheck disable=SC2064
  trap "rm -f '$d/.lock' 2>/dev/null || true" EXIT
}

print_endpoints() {
  local d="$1" name="$2"
  local host external_host port user
  host="$(ssh_host_for "$d")"
  external_host="$(external_host_hint)"
  port="$( [ -f "$d/port" ] && cat "$d/port" || echo - )"
  user="$(ssh_user "$d")" || return 1
  echo "  ssh (from this host):     vm ssh $name   (or: ssh -p $port -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null $user@$host)"
  echo "  ssh (from another host):  ssh -p $port -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null $user@$external_host"
  echo "  console:                  vm console $name   (tails $d/serial.log)"
  echo "  ports (list):             vm ports $name"
  echo "  publish a port:           vm publish $name <guest-port> [<host-port>]"
  echo "  shares (list):            vm shares $name"
  echo "  share a directory:        vm share $name <tag> <host-path> <guest-path>"
  echo "  gvproxy API:              curl --unix-socket $d/network.sock http://_/services/forwarder/all"
  case "$(uname -s)" in
    Linux)  echo "  qemu monitor:             socat - UNIX-CONNECT:$d/qemu.mon" ;;
    Darwin) echo "  vfkit control:            curl --unix-socket $d/vfkit.sock http://_/vm/state" ;;
  esac
}

cmd_start() {
  local name=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -*) echo "Unknown flag: $1" >&2; exit 1 ;;
      *)
        [ -z "$name" ] || { echo "Usage: vm start <name>" >&2; exit 1; }
        name="$1"; shift
        ;;
    esac
  done
  [ -n "$name" ] || { echo "Usage: vm start <name>" >&2; exit 1; }
  validate_name "$name"

  require_cmd jq
  require_cmd curl
  require_cmd uname

  # Host + image arch detection.
  local image_system image_arch host_os host_arch driver
  image_system="$(host_image_system)" || exit 1
  image_arch="${image_system%-linux}"
  host_os="$(uname -s)"
  host_arch="$(uname -m)"
  # uname -m reports "arm64" on Darwin, "aarch64" on Linux — normalize.
  [ "$host_arch" = "arm64" ] && host_arch="aarch64"

  if [ "$image_arch" != "$host_arch" ]; then
    echo "Cross-arch emulation not supported: $image_arch guest on $host_arch host. Run on a $image_arch host." >&2
    exit 1
  fi

  # Driver selection.
  case "$host_os" in
    Linux)
      require_cmd ss
      [ -e /dev/kvm ] || { echo "KVM not available (need /dev/kvm)." >&2; exit 1; }
      driver="qemu"
      ;;
    Darwin)
      driver="vfkit"
      ;;
    *)
      echo "Unsupported host OS: $host_os" >&2
      exit 1
      ;;
  esac

  local d disk metadata
  d="$(vm_dir "$name")"
  mkdir -p "$d"
  # Hold the launch lock across is_running → gvproxy launch → driver
  # launch → pidfile writes. Released by the EXIT trap installed
  # inside acquire_launch_lock. Ordering is load-bearing: is_running must
  # run *inside* the lock so two concurrent `vm start`s can't both
  # observe "not running" and both proceed to launch.
  acquire_launch_lock "$d" || exit 1
  disk="$(disk_path_for "$d")"
  metadata="$(metadata_disk_path_for "$d")"

  if is_running "$d/vm.pid"; then
    local host port
    host="$(ssh_host_for "$d")"
    port="$(cat "$d/port")"
    echo "VM '$name' is already running (pid $(cat "$d/vm.pid"), $host:$port)."
    echo "Nothing to do. Run 'vm restart $name' to restart it."
    return 0
  fi

  # Defensive cleanup of a stranded gvproxy from a previous launch
  # that was SIGKILL'd between gvproxy start and driver start. Safe
  # to call when there's nothing to stop.
  stop_gvproxy "$d"
  stop_virtiofsd "$d"
  stop_guest_share_mounter "$d"

  if [ ! -f "$disk" ]; then
    local golden; golden="$(ensure_golden)"
    echo "Installing VM disk from $golden..."
    rm -f "$disk.partial"
    copy_image "$golden" "$disk.partial"
    chmod u+w "$disk.partial"
    mv "$disk.partial" "$disk"
    # Snapshot the golden's sidecar so `vm list` can report what this
    # specific VM was baked from, even after later rebakes.
    cp "$(meta_for_golden "$golden")" "$d/meta.json"
  fi

  ssh_user "$d" >/dev/null || exit 1
  validate_shares_file "$d" || exit 1
  validate_share_paths_for_start "$d" || exit 1
  write_metadata_disk "$d" "$name"

  # Allocate or reuse the host SSH port. gvproxy's -ssh-port flag
  # binds 127.0.0.1:$port → guest:22 as a built-in forward; additional
  # forwards (including 0.0.0.0 binds for external access) go through
  # the forwarder API later via `vm publish`.
  local port
  if [ -f "$d/port" ]; then
    port="$(cat "$d/port")"
    if port_in_use "$port"; then
      echo "Stored port $port for VM '$name' is in use; reallocating." >&2
      port="$(allocate_port)"
      echo "$port" > "$d/port"
    fi
  else
    port="$(allocate_port)"
    echo "$port" > "$d/port"
  fi

  # qemu/vfkit/gvproxy run detached, so a signal
  # between launch and trap installation would leave processes
  # running and sockets bound. Install the trap *before* any launch
  # so it covers the whole dance. The explicit `exit 130` is
  # load-bearing: it guarantees the EXIT trap (installed by
  # acquire_launch_lock) fires and removes $d/.lock. Do not replace with
  # a bare return.
  trap 'echo >&2; echo "Interrupted - stopping VM." >&2; cmd_stop "$name" || true; exit 130' INT TERM

  : > "$d/serial.log"

  # gvproxy must be up before the driver — the driver connects to
  # gvproxy's VM-side socket on startup.
  if ! start_gvproxy "$d" "$driver" "$port"; then
    trap - INT TERM
    exit 1
  fi

  if ! case "$driver" in
    qemu)  boot_qemu  "$d" "$name" "$image_arch" "$disk" "$metadata" ;;
    vfkit) boot_vfkit "$d" "$name" "$disk" "$metadata" ;;
  esac; then
    stop_virtiofsd "$d"
    stop_gvproxy "$d"
    trap - INT TERM
    exit 1
  fi

  trap - INT TERM

  start_guest_share_mounter "$d" "$port"

  echo ""
  echo "VM '$name' launched (pid $(cat "$d/vm.pid"))."
  echo "(For live boot output: vm console $name)"
  print_endpoints "$d" "$name"
}

boot_qemu() {
  local d="$1" name="$2" image_arch="$3" disk="$4" metadata="$5"
  local qemu_bin="qemu-system-$image_arch"
  require_cmd "$qemu_bin"
  require_cmd setsid

  echo "Starting VM '$name' via qemu (gvproxy network)..."
  rm -f "$d/qemu.mon"

  local mac; mac="$(vm_mac "$name")"

  # -netdev stream (qemu 7.2+): client-side unix stream socket into
  # gvproxy's -listen-qemu endpoint. Run QEMU in the foreground under
  # a new session rather than using -daemonize; daemonizing closes the
  # stream backend connection on some hosts, leaving QEMU alive without
  # gvproxy.
  local qemu_args=(
    -enable-kvm -cpu host -smp 4 -m 4096
  )

  local share_count; share_count="$(shares_count "$d")"
  if [ "$share_count" -gt 0 ]; then
    qemu_args+=(
      -object "memory-backend-memfd,id=mem,size=4096M,share=on"
    )
  fi

  qemu_args+=(
    -drive "file=$disk,if=virtio"
    -drive "file=$metadata,if=virtio,format=raw,readonly=on"
    -netdev "stream,id=net0,server=off,addr.type=unix,addr.path=$d/qemu-net.sock"
    -device "virtio-net-pci,netdev=net0,mac=$mac"
    -display none
    -serial "file:$d/serial.log"
    -monitor "unix:$d/qemu.mon,server,nowait"
    -pidfile "$d/vm.pid"
  )

  if [ "$share_count" -gt 0 ]; then
    local shares; shares="$(shares_path_for "$d")"
    local idx=0 tag host_path share_readonly
    while IFS=$'\t' read -r tag host_path share_readonly; do
      [ -n "$tag" ] || continue
      start_virtiofsd "$d" "$tag" "$host_path" "$share_readonly" || return 1
      qemu_args+=(
        -chardev "socket,id=chrfs$idx,path=$d/virtiofs-$tag.sock"
        -device "vhost-user-fs-pci,chardev=chrfs$idx,tag=$tag,queue-size=1024"
      )
      idx=$((idx + 1))
    done < <(jq -r '.[] | [.tag, .hostPath, .readonly] | @tsv' "$shares")
  fi

  if [ "$image_arch" = "aarch64" ]; then
    local uefi
    uefi="$(find_aarch64_uefi)" || {
      echo "aarch64 UEFI firmware not found. Install qemu or set VM_QEMU_AARCH64_UEFI." >&2
      exit 1
    }
    if [ "$share_count" -gt 0 ]; then
      qemu_args=(-machine "virt,memory-backend=mem" "${qemu_args[@]}" -bios "$uefi")
    else
      qemu_args=(-machine virt "${qemu_args[@]}" -bios "$uefi")
    fi
  elif [ "$share_count" -gt 0 ]; then
    qemu_args=(-machine "memory-backend=mem" "${qemu_args[@]}")
  fi

  rm -f "$d/vm.pid"
  setsid -f "$qemu_bin" "${qemu_args[@]}" > "$d/qemu.log" 2>&1 < /dev/null

  # Detect immediate startup failure (bad flags, missing KVM, socket
  # connection failure, etc.). QEMU writes the pidfile after startup.
  local pid=""
  for _ in $(seq 1 50); do
    if [ -s "$d/vm.pid" ]; then
      pid="$(cat "$d/vm.pid")"
      if kill -0 "$pid" 2>/dev/null; then
        return 0
      fi
      break
    fi
    sleep 0.1
  done
  echo "qemu exited immediately. Check $d/qemu.log" >&2
  return 1
}

boot_vfkit() {
  local d="$1" name="$2" disk="$3" metadata="$4"
  require_cmd vfkit

  # Per-VM EFI variable store; created on first boot, reused thereafter.
  local efi_store="$d/efi-vars.fd"
  local bootloader="efi,variable-store=$efi_store"
  [ -f "$efi_store" ] || bootloader="$bootloader,create=true"

  local mac; mac="$(vm_mac "$name")"
  local sock="$d/vfkit.sock"
  rm -f "$sock"

  echo "Starting VM '$name' via vfkit (gvproxy network)..."

  # virtio-net,unixSocketPath: vfkit connects to gvproxy's
  # -listen-vfkit unixgram socket. Replaces the former vmnet NAT
  # plus /var/db/dhcpd_leases IP discovery dance.
  local vfkit_args=(
    --cpus 4
    --memory 4096
    --bootloader "$bootloader"
    --device "virtio-blk,path=$disk"
    --device "virtio-blk,path=$metadata"
    --device "virtio-net,unixSocketPath=$d/vfkit-net.sock,mac=$mac"
    --device virtio-rng
    --device "virtio-serial,logFilePath=$d/serial.log"
    --restful-uri "unix://$sock"
  )

  local shares; shares="$(shares_path_for "$d")"
  if [ -f "$shares" ]; then
    local tag host_path share_readonly
    while IFS=$'\t' read -r tag host_path share_readonly; do
      [ -n "$tag" ] || continue
      if [ "$share_readonly" = "true" ]; then
        echo "Warning: vfkit has no documented host-side readonly flag for virtio-fs; share '$tag' will be mounted read-only in the guest." >&2
      fi
      vfkit_args+=(--device "virtio-fs,sharedDir=$host_path,mountTag=$tag")
    done < <(jq -r '.[] | [.tag, .hostPath, .readonly] | @tsv' "$shares")
  fi

  nohup vfkit "${vfkit_args[@]}" > "$d/vfkit.log" 2>&1 &
  local pid=$!
  echo "$pid" > "$d/vm.pid"
  disown "$pid" 2>/dev/null || true

  # Detect immediate startup failure (bad flags, missing firmware, etc).
  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "vfkit exited immediately. Check $d/vfkit.log" >&2
    exit 1
  fi
}

cmd_stop() {
  require_arg_count "vm stop <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"

  if is_running "$d/vm.pid"; then
    local pid; pid="$(cat "$d/vm.pid")"
    local port=""
    [ -f "$d/port" ] && port="$(cat "$d/port")"

    if [ -n "$port" ] && try_guest_unmount_shares "$d" "$port"; then
      echo "Unmounted guest shares for VM '$name'."
    fi

    if try_graceful_shutdown "$d/qemu.mon"; then
      echo "Sent ACPI power-down to VM '$name' (pid $pid); waiting up to 20s..."
    elif try_vfkit_graceful_shutdown "$d/vfkit.sock"; then
      echo "Sent Stop request to vfkit VM '$name' (pid $pid); waiting up to 20s..."
    else
      echo "Stopping VM '$name' (pid $pid) via SIGTERM..."
      kill "$pid" 2>/dev/null || true
    fi

    for _ in $(seq 1 20); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 1
    done

    if kill -0 "$pid" 2>/dev/null; then
      echo "Still alive after 20s, sending SIGKILL (may corrupt disk)." >&2
      kill -9 "$pid" 2>/dev/null || true
    fi
  else
    echo "VM '$name' is not running."
  fi

  rm -f "$d/vm.pid" "$d/qemu.mon" "$d/vfkit.sock"
  stop_guest_share_mounter "$d"

  # gvproxy teardown is unconditional: even if the driver was already
  # stopped, stop_gvproxy cleans up stale pid/sockets and is a no-op
  # when nothing is running.
  stop_gvproxy "$d"
  stop_virtiofsd "$d"
}

cmd_restart() {
  require_arg_count "vm restart <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  cmd_stop "$name"
  cmd_start "$name"
}

normalize_grow_amount() {
  local raw="${1:-10G}"
  raw="${raw^^}"

  if [[ "$raw" =~ ^([1-9][0-9]*)([KMGTPE]?I?B?)?$ ]]; then
    local n="${BASH_REMATCH[1]}"
    local unit="${BASH_REMATCH[2]}"
    if [[ "$unit" =~ ^I?B$ ]]; then
      echo "Invalid grow amount: $raw (examples: 10G, 25GB, 1T)." >&2
      return 1
    fi
    unit="${unit%B}"
    unit="${unit%I}"
    [ -n "$unit" ] || unit="G"
    echo "${n}${unit}"
    return 0
  fi

  echo "Invalid grow amount: $raw (examples: 10G, 25GB, 1T)." >&2
  return 1
}

disk_virtual_size() {
  local disk="$1"
  if command -v qemu-img >/dev/null 2>&1; then
    qemu-img info "$disk" | awk -F': ' '/virtual size:/ { print $2; exit }'
  else
    printf '%s bytes\n' "$(wc -c < "$disk" | tr -d ' ')"
  fi
}

cmd_grow() {
  [ "$#" -ge 1 ] && [ "$#" -le 2 ] || { echo "Usage: vm grow <name> [amount]" >&2; exit 1; }
  local name="$1"
  local amount; amount="$(normalize_grow_amount "${2:-10G}")" || exit 1
  validate_name "$name"

  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }

  acquire_launch_lock "$d" || exit 1
  if is_running "$d/vm.pid"; then
    echo "VM '$name' is running. Stop it before growing its disk." >&2
    exit 1
  fi

  local disk; disk="$(existing_disk_path_for "$d")" || exit 1
  local before after
  before="$(disk_virtual_size "$disk")"

  case "$disk" in
    *.qcow2)
      require_cmd qemu-img
      qemu-img resize "$disk" "+$amount" >/dev/null
      ;;
    *.raw)
      if command -v qemu-img >/dev/null 2>&1; then
        qemu-img resize "$disk" "+$amount" >/dev/null
      else
        require_cmd truncate
        truncate -s "+$amount" "$disk"
      fi
      ;;
    *)
      echo "Unsupported VM disk format: $disk" >&2
      exit 1
      ;;
  esac

  after="$(disk_virtual_size "$disk")"
  echo "Grew VM '$name' disk by $amount."
  echo "  disk:   $disk"
  echo "  before: $before"
  echo "  after:  $after"
  echo "Start the VM for NixOS to grow the partition and filesystem."
}

cmd_wipe() {
  require_arg_count "vm wipe <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }

  # Hold the launch lock so a concurrent `vm start <same name>` cannot
  # recreate state while this command is removing it.
  acquire_launch_lock "$d" || exit 1
  cmd_stop "$name" || true
  rm -f "$d/disk.qcow2" "$d/disk.raw" "$d/efi-vars.fd" "$d/metadata.raw" "$d/meta.json"
  echo "Wiped VM '$name' disk/boot state. Run 'vm start $name' to recreate it from the current golden image."
}

cmd_destroy() {
  require_arg_count "vm destroy <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  # Hold the launch lock so a concurrent `vm start <same name>` can't tear
  # in mid-removal. Skip the lock if the state dir is already gone —
  # `ln -s` into a nonexistent directory would fail forever. The EXIT
  # trap's rm -f is a harmless no-op after `rm -rf "$d"` completes.
  if [ -d "$d" ]; then
    acquire_launch_lock "$d" || exit 1
  fi
  cmd_stop "$name" || true
  rm -rf "$d"
  echo "Removed VM '$name'."
}

cmd_ssh() {
  local name="${1:?Usage: vm ssh <name> [args...]}"; shift
  validate_name "$name"
  require_cmd ssh
  local d; d="$(vm_dir "$name")"
  is_running "$d/vm.pid" || { echo "VM '$name' is not running." >&2; exit 1; }
  local port; port="$(cat "$d/port")"
  local host; host="$(ssh_host_for "$d")"
  local user; user="$(ssh_user "$d")" || exit 1
  local opts; opts="$(ssh_opts)"
  # shellcheck disable=SC2086
  exec ssh -p "$port" $opts "$user@$host" "$@"
}

cmd_switch() {
  local name="${1:?Usage: vm switch <name> [nixos-rebuild args...]}"; shift
  validate_name "$name"
  if [ "$(uname -s)" != "Linux" ]; then
    echo "vm switch is only supported on Linux hosts for now." >&2
    echo "On Darwin, rebuild the golden image or update from inside the VM." >&2
    exit 1
  fi
  require_cmd nixos-rebuild
  require_cmd ssh
  require_cmd nix

  local d; d="$(vm_dir "$name")"
  is_running "$d/vm.pid" || { echo "VM '$name' is not running." >&2; exit 1; }

  local repo image_system port host opts target flake_target
  repo="$(repo_root)" || exit 1
  image_system="$(host_image_system)" || exit 1
  flake_target="vm-${image_system}-qcow"
  port="$(cat "$d/port")"
  host="$(ssh_host_for "$d")"
  opts="$(ssh_opts)"
  target="root@$host"

  echo "Switching VM '$name' using flake target .#$flake_target..."
  # shellcheck disable=SC2086
  NIX_SSHOPTS="-p $port $opts" \
    nixos-rebuild switch \
      --flake "$repo#$flake_target" \
      --target-host "$target" \
      "$@"
  record_switch_meta "$d" "$flake_target" "$repo"
}

cmd_console() {
  require_arg_count "vm console <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name' — did you mean 'vm start $name'?" >&2; exit 1; }
  # `tail -F` = `tail -f --retry`: waits for the file to appear if it's
  # not yet created (driver still starting) and follows across rotation.
  # `-n +1` starts from the top so a late-attaching console sees the
  # full boot log. This pairs with the `: > serial.log` truncation in
  # cmd_start — without it, -n +1 would dump the concatenated history of
  # every prior boot.
  exec tail -n +1 -F "$d/serial.log"
}

cmd_info() {
  require_arg_count "vm info <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }

  local status="stopped"
  is_running "$d/vm.pid" && status="running"

  echo "VM '$name' ($status)"
  print_endpoints "$d" "$name"
}

cmd_share() {
  local readonly=false
  [ "$#" -ge 4 ] || { echo "Usage: vm share <name> <tag> <host-path> <guest-path> [--readonly]" >&2; exit 1; }
  local name="$1" tag="$2" host_path="$3" guest_path="$4"
  shift 4
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --readonly) readonly=true; shift ;;
      -*) echo "Unknown flag: $1" >&2; exit 1 ;;
      *) echo "Unexpected argument: $1" >&2; exit 1 ;;
    esac
  done

  validate_name "$name"
  validate_share_tag "$tag" || exit 1
  validate_host_path "$host_path" || exit 1
  validate_guest_path "$guest_path" || exit 1
  require_cmd jq

  host_path="$(canonical_host_path "$host_path")"

  local d; d="$(vm_dir "$name")"
  mkdir -p "$d"
  acquire_launch_lock "$d" || exit 1
  ensure_shares_file "$d"
  validate_shares_file "$d" || exit 1

  local shares; shares="$(shares_path_for "$d")"
  if jq -e --arg tag "$tag" 'any(.[]; .tag == $tag)' "$shares" >/dev/null; then
    echo "Share '$tag' already exists for VM '$name'. Run 'vm unshare $name $tag' first to replace it." >&2
    exit 1
  fi

  jq \
    --arg tag "$tag" \
    --arg host_path "$host_path" \
    --arg guest_path "$guest_path" \
    --argjson readonly "$readonly" \
    '. + [{tag: $tag, hostPath: $host_path, guestPath: $guest_path, readonly: $readonly}]' \
    "$shares" > "$shares.partial"
  mv "$shares.partial" "$shares"

  echo "Shared $host_path as '$tag' at $guest_path for VM '$name'."
  if is_running "$d/vm.pid"; then
    echo "Restart VM '$name' for the new share to take effect."
  fi
}

cmd_unshare() {
  require_arg_count "vm unshare <name> <tag>" 2 "$@"
  local name="$1" tag="$2"
  validate_name "$name"
  validate_share_tag "$tag" || exit 1
  require_cmd jq

  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }
  acquire_launch_lock "$d" || exit 1
  ensure_shares_file "$d"
  validate_shares_file "$d" || exit 1

  local shares; shares="$(shares_path_for "$d")"
  if ! jq -e --arg tag "$tag" 'any(.[]; .tag == $tag)' "$shares" >/dev/null; then
    echo "No share '$tag' for VM '$name'." >&2
    exit 1
  fi

  jq --arg tag "$tag" 'map(select(.tag != $tag))' "$shares" > "$shares.partial"
  mv "$shares.partial" "$shares"

  echo "Removed share '$tag' from VM '$name'."
  if is_running "$d/vm.pid"; then
    echo "Restart VM '$name' for the removal to take effect."
  fi
}

cmd_shares() {
  require_arg_count "vm shares <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  require_cmd jq

  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }
  local shares; shares="$(shares_path_for "$d")"
  if [ ! -f "$shares" ] || [ "$(jq 'length' "$shares")" = "0" ]; then
    echo "No shares for VM '$name'."
    return 0
  fi
  validate_shares_file "$d" || exit 1
  printf "%-16s %-36s %-28s %s\n" TAG HOST-PATH GUEST-PATH MODE
  jq -r '.[] | [.tag, .hostPath, .guestPath, (if .readonly then "ro" else "rw" end)] | @tsv' "$shares" |
    while IFS=$'\t' read -r tag host_path guest_path mode; do
      printf "%-16s %-36s %-28s %s\n" "$tag" "$host_path" "$guest_path" "$mode"
    done
}

# Parse publish/unpublish positional args + flags. Populates globals
# _PARSE_NAME / _PARSE_PORTS (array) / _PARSE_BIND (empty = 0.0.0.0) /
# _PARSE_AUTO (0/1). Avoids subshell gymnastics around arrays.
_parse_forward_args() {
  _PARSE_NAME=""
  _PARSE_BIND=""
  _PARSE_AUTO=0
  _PARSE_PORTS=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bind)
        [ "$#" -ge 2 ] || { echo "--bind requires an address." >&2; return 1; }
        _PARSE_BIND="$2"; shift 2
        ;;
      --bind=*) _PARSE_BIND="${1#--bind=}"; shift ;;
      --auto)   _PARSE_AUTO=1; shift ;;
      -*)       echo "Unknown flag: $1" >&2; return 1 ;;
      *)
        if [ -z "$_PARSE_NAME" ]; then
          _PARSE_NAME="$1"
        else
          _PARSE_PORTS+=("$1")
        fi
        shift
        ;;
    esac
  done
}

cmd_publish() {
  _parse_forward_args "$@" || exit 1
  [ -n "$_PARSE_NAME" ] && [ "${#_PARSE_PORTS[@]}" -ge 1 ] || {
    echo "Usage: vm publish <name> <guest-port> [<host-port>] [--bind <addr>] [--auto]" >&2
    exit 1
  }
  [ "${#_PARSE_PORTS[@]}" -le 2 ] || {
    echo "Too many port arguments to 'vm publish'." >&2; exit 1
  }
  validate_name "$_PARSE_NAME"
  local guest_port="${_PARSE_PORTS[0]}"
  local host_port=""
  if [ "$_PARSE_AUTO" = "1" ]; then
    [ "${#_PARSE_PORTS[@]}" -eq 1 ] || {
      echo "--auto is incompatible with an explicit host-port." >&2; exit 1
    }
    host_port="$(allocate_free_port)" || exit 1
  else
    host_port="${_PARSE_PORTS[1]:-$guest_port}"
  fi
  local d; d="$(vm_dir "$_PARSE_NAME")"
  is_running "$d/vm.pid" || { echo "VM '$_PARSE_NAME' is not running." >&2; exit 1; }
  # Empty _PARSE_BIND → ":$port", which gvproxy interprets as 0.0.0.0.
  local local_addr="$_PARSE_BIND:$host_port"
  if forwarder_expose "$d" "$local_addr" "$GVPROXY_GUEST:$guest_port" >/dev/null; then
    if [ "$_PARSE_AUTO" = "1" ]; then
      # stdout is just the port so `port=$(vm publish $name P --auto)` works.
      echo "Published $local_addr → $GVPROXY_GUEST:$guest_port" >&2
      echo "$host_port"
    else
      echo "Published $local_addr → $GVPROXY_GUEST:$guest_port"
    fi
  else
    exit 1
  fi
}

cmd_unpublish() {
  _parse_forward_args "$@" || exit 1
  [ -n "$_PARSE_NAME" ] && [ "${#_PARSE_PORTS[@]}" -eq 1 ] && [ "$_PARSE_AUTO" = "0" ] || {
    echo "Usage: vm unpublish <name> <host-port> [--bind <addr>]" >&2
    exit 1
  }
  validate_name "$_PARSE_NAME"
  local host_port="${_PARSE_PORTS[0]}"
  local d; d="$(vm_dir "$_PARSE_NAME")"
  is_running "$d/vm.pid" || { echo "VM '$_PARSE_NAME' is not running." >&2; exit 1; }
  local local_addr="$_PARSE_BIND:$host_port"
  if forwarder_unexpose "$d" "$local_addr" >/dev/null; then
    echo "Unpublished $local_addr"
  else
    exit 1
  fi
}

cmd_ports() {
  require_arg_count "vm ports <name>" 1 "$@"
  local name="$1"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  is_running "$d/vm.pid" || { echo "VM '$name' is not running." >&2; exit 1; }
  # gvproxy returns an array of {local, remote, protocol}. Empty array
  # is a valid "no forwards yet" response.
  local json
  json="$(forwarder_list "$d")" || exit 1
  if [ "$(printf '%s' "$json" | jq 'length')" = "0" ]; then
    echo "No forwards for VM '$name'."
    return 0
  fi
  printf '%s\n' "$json" | jq -r '.[] | "  \(.protocol // "tcp")  \(.local)  →  \(.remote)"'
}

cmd_list() {
  require_arg_count "vm list" 0 "$@"
  local any=0
  local fmt="%-18s %-9s %-22s %-7s %-11s %-10s %s\n"
  for d in "$VMS_DIR"/*/; do
    [ -d "$d" ] || continue
    if [ "$any" -eq 0 ]; then
      # shellcheck disable=SC2059
      printf "$fmt" NAME STATUS SSH SIZE BAKED REV DIR
      any=1
    fi
    local name status host port ssh_endpoint size baked rev
    name="$(basename "$d")"
    status="stopped"
    is_running "$d/vm.pid" && status="running"
    host="$(ssh_host_for "$d")"
    port="$( [ -f "$d/port" ] && cat "$d/port" || echo - )"
    ssh_endpoint="$host:$port"
    size="-"
    local ext
    for ext in qcow2 raw; do
      if [ -f "$d/disk.$ext" ]; then
        size="$(du -h "$d/disk.$ext" | cut -f1)"
        break
      fi
    done
    baked="-"
    rev="-"
    if [ -f "$d/meta.json" ] && command -v jq >/dev/null 2>&1; then
      baked="$(jq -r '.baked_at // "-"' "$d/meta.json")"
      baked="${baked:0:10}"
      local r
      r="$(jq -r '.switch_flake_rev // .flake_rev // "-"' "$d/meta.json")"
      if [[ "$r" == *-dirty ]]; then
        rev="${r%%-dirty}"; rev="${rev:0:7}*"
      else
        rev="${r:0:8}"
      fi
    fi

    # shellcheck disable=SC2059
    printf "$fmt" "$name" "$status" "$ssh_endpoint" "$size" "$baked" "$rev" "$d"
  done
  [ "$any" -eq 0 ] && echo "No VMs."
  return 0
}

case "${1:-}" in
  start|up) shift; cmd_start "$@" ;;
  stop|halt) shift; cmd_stop "$@" ;;
  restart) shift; cmd_restart "$@" ;;
  grow) shift; cmd_grow "$@" ;;
  wipe) shift; cmd_wipe "$@" ;;
  destroy|rm) shift; cmd_destroy "$@" ;;
  ssh) shift; cmd_ssh "$@" ;;
  switch) shift; cmd_switch "$@" ;;
  console) shift; cmd_console "$@" ;;
  info) shift; cmd_info "$@" ;;
  list|ls) shift; cmd_list "$@" ;;
  publish) shift; cmd_publish "$@" ;;
  unpublish) shift; cmd_unpublish "$@" ;;
  ports) shift; cmd_ports "$@" ;;
  share) shift; cmd_share "$@" ;;
  unshare) shift; cmd_unshare "$@" ;;
  shares) shift; cmd_shares "$@" ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown subcommand: $1" >&2; usage >&2; exit 1 ;;
esac
