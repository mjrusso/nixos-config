#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: vm <subcommand> [args]

Subcommands:
  up <name> [--rebuild] [--no-wait]
        Boot a VM from the host's golden image.
        --rebuild         wipe the VM's disk and reinstall from the
                          current golden image (destroys VM state)
        --no-wait         return as soon as the VM process is launched;
                          skip the SSH readiness check.
  down <name>             Stop the VM (graceful kill, then SIGKILL).
  rm <name>               Stop and delete the VM and all its state.
  ssh <name> [args...]    SSH into the VM.
  console <name>          Stream the VM's serial log (follows live boot
                          output; Ctrl-C detaches without touching the VM).
  info <name>             Print connection info (ssh/console/monitor)
                          for an existing VM.
  list                    List known VMs and their status.

State directory: $VMS_DIR (default: ~/vms). Golden images and their
`.meta.json` sidecars are expected there — bake them from the
nixos-config repo:

  ./scripts/bake-golden

Networking depends on the backend:
  - qemu (Linux): user-mode NAT with hostfwd; SSH port auto-allocated
    from 2222-2299 and persisted per VM.
  - vfkit (Darwin): vmnet NAT with DHCP; SSH goes to the guest's
    assigned IP on port 22 (resolved from /var/db/dhcpd_leases).
USAGE
}

VMS_DIR="${VMS_DIR:-$HOME/vms}"
# Sanity-check VMS_DIR before anything in this script does `rm -rf` under it.
if [ -z "$VMS_DIR" ] || [ "$VMS_DIR" = "/" ]; then
  echo "Refusing to operate with VMS_DIR='$VMS_DIR'." >&2
  exit 1
fi
# Reject whitespace and shell metacharacters in VMS_DIR. The only
# *load-bearing* character is "'" — acquire_up_lock installs an EXIT
# trap whose body embeds $d (= $VMS_DIR/$name) inside single quotes,
# and a stray "'" there would break out of the quoting and inject
# shell. The rest are hygiene (whitespace breaks unquoted expansions
# elsewhere in the script; the remaining metacharacters are
# belt-and-suspenders against future refactors that might drop the
# single quotes around $d). validate_name further restricts $name to
# [a-zA-Z0-9_-]; both halves of $d have to stay clean.
case "$VMS_DIR" in
  *"'"*|*[$' \t\n\r"`$\\;&|<>(){}*?!#~']*)
    echo "Refusing to operate with VMS_DIR containing whitespace or shell metacharacters: '$VMS_DIR'." >&2
    exit 1
    ;;
esac
PORT_LOW=2222
PORT_HIGH=2299

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "Missing required command: $1" >&2; exit 1; }
}

# Copy an image file preserving sparseness. Darwin's BSD cp has no
# sparse detection, so a cp of a (potentially sparse) raw image fully
# allocates the destination — which means every `vm up` would balloon
# ~/vms by the full logical disk size. `cp -c` uses clonefile(2) for
# an instant CoW clone when source and destination are on the same
# APFS volume, which is both faster and disk-space-free. Fall back to
# plain cp when clonefile isn't possible (cross-volume, non-APFS) or
# on Linux, where GNU cp's default --sparse=auto handles it.
copy_image() {
  local src="$1" dst="$2"
  if [ "$(uname -s)" = "Darwin" ] && cp -c "$src" "$dst" 2>/dev/null; then
    return 0
  fi
  cp "$src" "$dst"
}

meta_for_golden() {
  echo "$1.meta.json"
}

ssh_user() {
  # $1: a VM's state directory. Read the username from its meta.json
  # sidecar, snapshotted at `up` time and pinned to the golden the VM
  # was actually installed from, so later rebakes don't produce
  # mismatches.
  #
  # Typically called via command substitution, so use `return` instead
  # of `exit` — callers should check the exit status (via `|| exit`).
  command -v jq >/dev/null 2>&1 || { echo "Missing required command: jq" >&2; return 1; }
  local meta="$1/meta.json"
  [ -f "$meta" ] || {
    echo "Missing meta sidecar: $meta" >&2
    echo "Run ./scripts/bake-golden from the nixos-config repo." >&2
    return 1
  }
  jq -r '.user' "$meta"
}

host_image_system() {
  case "$(uname -s)" in
    Linux)
      case "$(uname -m)" in
        x86_64) echo "x86_64-linux" ;;
        aarch64) echo "aarch64-linux" ;;
        *) echo "Unsupported host architecture: $(uname -m)" >&2; return 1 ;;
      esac
      ;;
    Darwin)
      # vfkit runs Linux guests natively on the host arch.
      case "$(uname -m)" in
        arm64|aarch64) echo "aarch64-linux" ;;
        x86_64) echo "x86_64-linux" ;;
        *) echo "Unsupported host architecture: $(uname -m)" >&2; return 1 ;;
      esac
      ;;
    *) echo "Unsupported host OS: $(uname -s)" >&2; return 1 ;;
  esac
}

host_image_format() {
  case "$(uname -s)" in
    Darwin) echo "raw" ;;     # vfkit uses raw disks
    *)      echo "qcow2" ;;   # qemu uses qcow2
  esac
}

# UEFI firmware is required for aarch64 qemu boots. The Nix wrapper
# pins VM_QEMU_AARCH64_UEFI to a known-good store path; fall back to
# standard system-package locations for non-Nix hosts.
find_aarch64_uefi() {
  if [ -n "${VM_QEMU_AARCH64_UEFI:-}" ] && [ -f "$VM_QEMU_AARCH64_UEFI" ]; then
    echo "$VM_QEMU_AARCH64_UEFI"
    return 0
  fi
  local p
  for p in \
      /usr/share/AAVMF/AAVMF_CODE.fd \
      /usr/share/qemu/edk2-aarch64-code.fd \
      /usr/share/edk2/aarch64/QEMU_EFI.fd; do
    if [ -f "$p" ]; then
      echo "$p"
      return 0
    fi
  done
  return 1
}

golden_image_path() {
  local system format
  system="$(host_image_system)" || return 1
  format="$(host_image_format)"
  echo "$VMS_DIR/golden-$system.$format"
}

ensure_golden() {
  local golden; golden="$(golden_image_path)"
  if [ ! -f "$golden" ]; then
    cat >&2 <<EOF
Golden image not found: $golden

Bake it from the nixos-config repo:
  ./scripts/bake-golden

EOF
    exit 1
  fi
  echo "$golden"
}

disk_path_for() {
  echo "$1/disk.$(host_image_format)"
}

ssh_host_for() {
  # Which host to SSH to for this VM. qemu runs with user-mode NAT and
  # hostfwd, so it's always localhost. vfkit's NAT gives the guest a
  # real IP on the host's virtual bridge, which boot_vfkit records.
  local d="$1"
  if [ -f "$d/ssh_host" ]; then
    cat "$d/ssh_host"
  else
    echo "localhost"
  fi
}

vm_mac() {
  # Deterministic MAC from VM name. Locally-administered OUI (02:*) so
  # there's no collision risk with real hardware.
  local name="$1" h
  if command -v md5sum >/dev/null 2>&1; then
    h="$(printf '%s' "$name" | md5sum | cut -c1-10)"
  else
    # Darwin has md5 (different CLI) instead of md5sum.
    h="$(printf '%s' "$name" | md5 -q | cut -c1-10)"
  fi
  printf '02:%s:%s:%s:%s:%s\n' "${h:0:2}" "${h:2:2}" "${h:4:2}" "${h:6:2}" "${h:8:2}"
}

# Parse macOS's DHCP lease file to map a MAC to its last-assigned IP.
# The file format is a series of `{ ... }` records with key=value lines,
# including `hw_address=1,<mac>` and `ip_address=<ip>`. Apple's bootpd
# strips leading zeros from each octet (e.g., 02:0a → 2:a), so normalize
# both sides before comparing.
vfkit_guest_ip_lookup() {
  local mac="$1"
  local leases="/var/db/dhcpd_leases"
  [ -r "$leases" ] || return 1
  awk -v mac="$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]')" '
    function strip_mac(m,    parts, n, i, v, out) {
      n = split(m, parts, ":")
      out = ""
      for (i = 1; i <= n; i++) {
        v = parts[i]; sub(/^0+/, "", v); if (v == "") v = "0"
        out = out (i>1 ? ":" : "") v
      }
      return out
    }
    BEGIN { RS="}"; FS="\n"; mac = strip_mac(mac) }
    {
      ip=""; hw=""
      for (i = 1; i <= NF; i++) {
        if ($i ~ /ip_address=/) { sub(/.*ip_address=[[:space:]]*/, "", $i); ip=$i }
        if ($i ~ /hw_address=/) {
          sub(/.*hw_address=[0-9]+,[[:space:]]*/, "", $i)
          hw=tolower($i)
        }
      }
      gsub(/[[:space:]\r]/, "", ip)
      gsub(/[[:space:]\r]/, "", hw)
      if (ip != "" && strip_mac(hw) == mac) { print ip; exit }
    }
  ' "$leases"
}

vfkit_wait_for_ip() {
  local mac="$1" ip
  for _ in $(seq 1 60); do
    ip="$(vfkit_guest_ip_lookup "$mac")"
    if [ -n "$ip" ]; then
      echo "$ip"
      return 0
    fi
    sleep 1
  done
  return 1
}

try_vfkit_graceful_shutdown() {
  local sock="$1"
  [ -S "$sock" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl --unix-socket "$sock" -X PUT \
       -H "Content-Type: application/json" \
       -d '{"state":"Stop"}' \
       --max-time 2 --silent --output /dev/null \
       "http://_/vm/state" >/dev/null 2>&1
}

validate_name() {
  local name="$1"
  [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]] || {
    echo "Invalid VM name '$name' (allowed: alphanumeric, '_', '-'; must not start with '-' or '_')." >&2
    exit 1
  }
}

vm_dir() { echo "$VMS_DIR/$1"; }

ssh_opts() {
  echo "-o StrictHostKeyChecking=no \
-o UserKnownHostsFile=/dev/null \
-o GlobalKnownHostsFile=/dev/null \
-o LogLevel=ERROR"
}

port_in_use() {
  ss -tlnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${1}\$"
}

allocate_port() {
  for port in $(seq "$PORT_LOW" "$PORT_HIGH"); do
    if ! port_in_use "$port"; then
      echo "$port"; return 0
    fi
  done
  echo "No free port in ${PORT_LOW}-${PORT_HIGH}" >&2
  exit 1
}

is_running() {
  local pidfile="$1"
  [ -f "$pidfile" ] || return 1
  local pid; pid="$(cat "$pidfile")"
  kill -0 "$pid" 2>/dev/null || return 1
  # Guard against PID reuse: check the live pid's command name matches one of
  # the drivers we know how to start. Prefer /proc/<pid>/cmdline's argv[0] over
  # /proc/<pid>/comm: comm is capped at TASK_COMM_LEN (15 chars) and reflects
  # the *exec'd* binary's name, which on NixOS is e.g.
  # `.qemu-system-x86_64-wrapped` (truncates to `.qemu-system-x8`, which fails
  # the qemu-system* match). NixOS's makeWrapper sets argv[0] to the unwrapped
  # name, so cmdline gives us `qemu-system-x86_64`.
  local comm
  if [ -r "/proc/$pid/cmdline" ]; then
    comm="$(tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | head -n1)" || return 1
    comm="${comm##*/}"
  else
    comm="$(ps -o comm= -p "$pid" 2>/dev/null)" || return 1
    comm="${comm##*/}"
  fi
  [[ "$comm" == qemu-system* ]] || [[ "$comm" == vfkit* ]]
}

try_graceful_shutdown() {
  local socket="$1"
  [ -S "$socket" ] || return 1
  command -v socat >/dev/null 2>&1 || return 1
  echo "system_powerdown" | socat - "UNIX-CONNECT:$socket" >/dev/null 2>&1
}

# Acquire a per-VM launch lock at $d/.lock (a symlink whose target is
# the holder's pid). symlink(2) is atomic on both Linux and Darwin,
# which makes the create-and-record-holder step a single syscall — no
# window where a reader can see the lock without a holder. Auto-recovers
# if the holder pid is dead.
acquire_up_lock() {
  local d="$1"
  while ! ln -s "$$" "$d/.lock" 2>/dev/null; do
    # Bail out if the state dir itself has vanished — a concurrent
    # `vm rm` already inside its own lock can `rm -rf "$d"` out from
    # under us, at which point `ln -s` fails with ENOENT forever and
    # the loop would spin.
    [ -d "$d" ] || return 1
    local holder=""
    holder="$(readlink "$d/.lock" 2>/dev/null || true)"
    if [ -n "$holder" ] && kill -0 "$holder" 2>/dev/null; then
      echo "vm up already in progress for $(basename "$d") (pid $holder)." >&2
      return 1
    fi
    # Re-check the target before unlinking, so a concurrent acquirer's
    # fresh lock (with a different target) isn't clobbered during our
    # TOCTOU window.
    local still=""
    still="$(readlink "$d/.lock" 2>/dev/null || true)"
    [ "$still" = "$holder" ] && rm -f "$d/.lock" 2>/dev/null || true
  done
  # This is the only EXIT trap in the script. Bash allows one handler
  # per signal, so adding another `trap ... EXIT` elsewhere would
  # silently replace this one and strand .lock files. If you need
  # another EXIT action, chain it here rather than installing a
  # second trap.
  # shellcheck disable=SC2064
  trap "rm -f '$d/.lock' 2>/dev/null || true" EXIT
}

print_endpoints() {
  local d="$1" name="$2"
  local host port user
  host="$(ssh_host_for "$d")"
  port="$( [ -f "$d/port" ] && cat "$d/port" || echo - )"
  user="$(ssh_user "$d")" || return 1
  echo "  ssh:     vm ssh $name   (or: ssh -p $port $user@$host)"
  echo "  console: vm console $name   (tails $d/serial.log)"
  case "$(uname -s)" in
    Linux)  echo "  monitor: socat - UNIX-CONNECT:$d/qemu.mon" ;;
    Darwin) echo "  control: curl --unix-socket $d/vfkit.sock http://_/vm/state" ;;
  esac
}

wait_for_ssh() {
  local host="$1" port="$2" user="$3"
  local opts; opts="$(ssh_opts)"
  echo -n "Waiting for SSH at $user@$host:$port"
  for _ in $(seq 1 90); do
    # shellcheck disable=SC2086
    if ssh -p "$port" -o ConnectTimeout=2 -o BatchMode=yes $opts "$user@$host" true 2>/dev/null; then
      echo " — up."
      return 0
    fi
    echo -n "."
    sleep 2
  done
  echo ""
  echo "Timed out waiting for SSH." >&2
  return 1
}

cmd_up() {
  local name="" rebuild=0 no_wait=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --rebuild) rebuild=1; shift ;;
      --no-wait) no_wait=1; shift ;;
      -*) echo "Unknown flag: $1" >&2; exit 1 ;;
      *) name="$1"; shift ;;
    esac
  done
  [ -n "$name" ] || { echo "Usage: vm up <name> [--rebuild] [--no-wait]" >&2; exit 1; }
  validate_name "$name"

  require_cmd ssh
  require_cmd jq
  require_cmd uname

  # Host + image arch detection.
  local image_system image_arch host_os host_arch driver
  image_system="$(host_image_system)" || exit 1
  image_arch="${image_system%-linux}"
  host_os="$(uname -s)"
  host_arch="$(uname -m)"
  # uname -m reports "arm64" on Darwin, "aarch64" on Linux — normalize.
  [ "$host_arch" = "arm64" ] && host_arch="aarch64"

  if [ "$image_arch" != "$host_arch" ]; then
    echo "Cross-arch emulation not supported: $image_arch guest on $host_arch host. Run on a $image_arch host." >&2
    exit 1
  fi

  # Driver selection.
  case "$host_os" in
    Linux)
      require_cmd ss
      [ -e /dev/kvm ] || { echo "KVM not available (need /dev/kvm)." >&2; exit 1; }
      driver="qemu"
      ;;
    Darwin)
      driver="vfkit"
      ;;
    *)
      echo "Unsupported host OS: $host_os" >&2
      exit 1
      ;;
  esac

  local d disk
  d="$(vm_dir "$name")"
  mkdir -p "$d"
  # Hold the launch lock across the is_running check → driver launch →
  # pidfile write window. Released by the EXIT trap installed inside
  # acquire_up_lock. Ordering is load-bearing: is_running must run
  # *inside* the lock so two concurrent `vm up`s can't both observe
  # "not running" and both proceed to launch.
  acquire_up_lock "$d" || exit 1
  disk="$(disk_path_for "$d")"

  if is_running "$d/vm.pid"; then
    if [ "$rebuild" -eq 1 ]; then
      echo "VM '$name' is running — stop it with 'vm down $name' before rebuilding." >&2
      exit 1
    fi
    local host port
    host="$(ssh_host_for "$d")"
    port="$(cat "$d/port")"
    echo "VM '$name' is already running (pid $(cat "$d/vm.pid"), $host:$port)."
    echo "Nothing to do. Run 'vm down $name' first to reboot."
    return 0
  fi

  if [ "$rebuild" -eq 1 ]; then
    # Full reset. Wipe either disk format (in case the host driver
    # changed since last boot) and EFI vars.
    rm -f "$d/disk.qcow2" "$d/disk.raw" "$d/efi-vars.fd"
  fi

  if [ ! -f "$disk" ]; then
    local golden; golden="$(ensure_golden)"
    echo "Installing VM disk from $golden..."
    rm -f "$disk.partial"
    copy_image "$golden" "$disk.partial"
    chmod u+w "$disk.partial"
    mv "$disk.partial" "$disk"
    # Snapshot the golden's sidecar so `vm list` can report what this
    # specific VM was baked from, even after later rebakes.
    cp "$(meta_for_golden "$golden")" "$d/meta.json"
  fi

  local user; user="$(ssh_user "$d")" || exit 1

  # qemu is daemonized and vfkit is nohup'd, so a signal between driver
  # launch and trap installation would otherwise leave the VM running
  # and holding its port. Install the trap *before* the launch so it
  # covers the launch itself. The explicit `exit 130` is load-bearing:
  # it guarantees the EXIT trap (installed by acquire_up_lock) fires
  # and removes $d/.lock. Do not replace with a bare return.
  trap 'echo >&2; echo "Interrupted — tearing down VM '"'"'$name'"'"'." >&2; cmd_down "$name" || true; exit 130' INT TERM

  : > "$d/serial.log"

  case "$driver" in
    qemu)  boot_qemu  "$d" "$name" "$image_arch" "$disk" ;;
    vfkit) boot_vfkit "$d" "$name" "$disk" ;;
  esac

  local host port
  host="$(ssh_host_for "$d")"
  port="$(cat "$d/port")"

  if [ "$no_wait" -eq 1 ]; then
    # Clear the signal trap: with --no-wait we're about to exit
    # cleanly, and we don't want a tty SIGHUP during shell teardown to
    # tear the VM the user just asked us to launch. The EXIT trap (lock
    # cleanup) stays.
    trap - INT TERM
    echo ""
    echo "VM '$name' launched (pid $(cat "$d/vm.pid")). SSH not verified."
  else
    echo "(For live boot output: vm console $name)"
    if ! wait_for_ssh "$host" "$port" "$user"; then
      echo "Tearing down unresponsive VM '$name'. Check $d/serial.log for boot output." >&2
      cmd_down "$name" || true
      exit 1
    fi
    trap - INT TERM

    echo ""
    echo "VM '$name' is up."
  fi
  print_endpoints "$d" "$name"
}

boot_qemu() {
  local d="$1" name="$2" image_arch="$3" disk="$4"
  local qemu_bin="qemu-system-$image_arch"
  require_cmd "$qemu_bin"

  local port
  if [ -f "$d/port" ]; then
    port="$(cat "$d/port")"
    if port_in_use "$port"; then
      echo "Stored port $port for VM '$name' is in use; reallocating." >&2
      port="$(allocate_port)"
      echo "$port" > "$d/port"
    fi
  else
    port="$(allocate_port)"
    echo "$port" > "$d/port"
  fi
  echo "localhost" > "$d/ssh_host"

  echo "Starting VM '$name' via qemu on ssh port $port..."
  rm -f "$d/qemu.mon" "$d/vfkit.sock"

  local qemu_args=(
    -enable-kvm -cpu host -smp 4 -m 4096
    -drive "file=$disk,if=virtio"
    -netdev "user,id=net0,hostfwd=tcp::${port}-:22"
    -device "virtio-net-pci,netdev=net0"
    -display none
    -serial "file:$d/serial.log"
    -monitor "unix:$d/qemu.mon,server,nowait"
    -pidfile "$d/vm.pid"
    -daemonize
  )

  if [ "$image_arch" = "aarch64" ]; then
    local uefi
    uefi="$(find_aarch64_uefi)" || {
      echo "aarch64 UEFI firmware not found. Install qemu or set VM_QEMU_AARCH64_UEFI." >&2
      exit 1
    }
    qemu_args=(-machine virt "${qemu_args[@]}" -bios "$uefi")
  fi

  "$qemu_bin" "${qemu_args[@]}"
}

boot_vfkit() {
  local d="$1" name="$2" disk="$3"
  require_cmd vfkit
  require_cmd curl

  # Per-VM EFI variable store; created on first boot, reused thereafter.
  local efi_store="$d/efi-vars.fd"
  local bootloader="efi,variable-store=$efi_store"
  [ -f "$efi_store" ] || bootloader="$bootloader,create=true"

  local mac; mac="$(vm_mac "$name")"
  local sock="$d/vfkit.sock"
  rm -f "$sock" "$d/qemu.mon"

  # Endpoint-file ordering: write the known-good value ($d/port = 22
  # for vfkit) and wipe any stale $d/ssh_host *before* launch, so a
  # SIGKILL of this launcher during the IP-discovery window can't
  # leave vfkit alive with endpoint files that disagree with reality.
  # The `nohup vfkit & echo $! > vm.pid` pair below still has a
  # microsecond window between fork and pidfile-write; backstops are
  # the launch lock held across this whole region by cmd_up, and
  # is_running's /proc/<pid>/comm check against vfkit*. Not worth the
  # extra sh -c wrapper to close the microsecond window.
  rm -f "$d/ssh_host"
  echo "22" > "$d/port"

  echo "Starting VM '$name' via vfkit..."

  # vfkit runs in the foreground and has no --daemonize equivalent, so
  # wrap with nohup to survive terminal close, redirect output, and
  # detach from the job table.
  nohup vfkit \
    --cpus 4 \
    --memory 4096 \
    --bootloader "$bootloader" \
    --device "virtio-blk,path=$disk" \
    --device "virtio-net,nat,mac=$mac" \
    --device virtio-rng \
    --device "virtio-serial,logFilePath=$d/serial.log" \
    --restful-uri "unix://$sock" \
    > "$d/vfkit.log" 2>&1 &
  local pid=$!
  echo "$pid" > "$d/vm.pid"
  disown "$pid" 2>/dev/null || true

  # Detect immediate startup failure (bad flags, missing firmware, etc).
  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "vfkit exited immediately. Check $d/vfkit.log" >&2
    exit 1
  fi

  echo -n "Discovering guest IP for MAC $mac"
  local ip
  ip="$(vfkit_wait_for_ip "$mac")" || {
    echo ""
    echo "Could not find guest IP in /var/db/dhcpd_leases." >&2
    echo "Guest may still be booting; check $d/serial.log." >&2
    exit 1
  }
  echo " — $ip"
  echo "$ip" > "$d/ssh_host"
}

cmd_down() {
  local name="${1:?Usage: vm down <name>}"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"

  if is_running "$d/vm.pid"; then
    local pid; pid="$(cat "$d/vm.pid")"

    if try_graceful_shutdown "$d/qemu.mon"; then
      echo "Sent ACPI power-down to VM '$name' (pid $pid); waiting up to 20s..."
    elif try_vfkit_graceful_shutdown "$d/vfkit.sock"; then
      echo "Sent Stop request to vfkit VM '$name' (pid $pid); waiting up to 20s..."
    else
      echo "Stopping VM '$name' (pid $pid) via SIGTERM..."
      kill "$pid" 2>/dev/null || true
    fi

    for _ in $(seq 1 20); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 1
    done

    if kill -0 "$pid" 2>/dev/null; then
      echo "Still alive after 20s, sending SIGKILL (may corrupt disk)." >&2
      kill -9 "$pid" 2>/dev/null || true
    fi
  else
    echo "VM '$name' is not running."
  fi

  rm -f "$d/vm.pid" "$d/qemu.mon" "$d/vfkit.sock"
}

cmd_rm() {
  local name="${1:?Usage: vm rm <name>}"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  # Hold the launch lock so a concurrent `vm up <same name>` can't tear
  # in mid-removal. Skip the lock if the state dir is already gone —
  # `ln -s` into a nonexistent directory would fail forever. The EXIT
  # trap's rm -f is a harmless no-op after `rm -rf "$d"` completes.
  if [ -d "$d" ]; then
    acquire_up_lock "$d" || exit 1
  fi
  cmd_down "$name" || true
  rm -rf "$d"
  echo "Removed VM '$name'."
}

cmd_ssh() {
  local name="${1:?Usage: vm ssh <name> [args...]}"; shift
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  is_running "$d/vm.pid" || { echo "VM '$name' is not running." >&2; exit 1; }
  local port; port="$(cat "$d/port")"
  local host; host="$(ssh_host_for "$d")"
  local user; user="$(ssh_user "$d")" || exit 1
  local opts; opts="$(ssh_opts)"
  # shellcheck disable=SC2086
  exec ssh -p "$port" $opts "$user@$host" "$@"
}

cmd_console() {
  local name="${1:?Usage: vm console <name>}"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name' — did you mean 'vm up $name'?" >&2; exit 1; }
  # `tail -F` = `tail -f --retry`: waits for the file to appear if it's
  # not yet created (driver still starting) and follows across rotation.
  # `-n +1` starts from the top so a late-attaching console sees the
  # full boot log. This pairs with the `: > serial.log` truncation in
  # cmd_up — without it, -n +1 would dump the concatenated history of
  # every prior boot.
  exec tail -n +1 -F "$d/serial.log"
}

cmd_info() {
  local name="${1:?Usage: vm info <name>}"
  validate_name "$name"
  local d; d="$(vm_dir "$name")"
  [ -d "$d" ] || { echo "No such VM '$name'." >&2; exit 1; }

  local status="stopped"
  is_running "$d/vm.pid" && status="running"

  echo "VM '$name' ($status)"
  print_endpoints "$d" "$name"
}

cmd_list() {
  local any=0
  local fmt="%-18s %-9s %-22s %-7s %-11s %-10s %s\n"
  for d in "$VMS_DIR"/*/; do
    [ -d "$d" ] || continue
    if [ "$any" -eq 0 ]; then
      # shellcheck disable=SC2059
      printf "$fmt" NAME STATUS SSH SIZE BAKED REV DIR
      any=1
    fi
    local name status host port ssh_endpoint size baked rev
    name="$(basename "$d")"
    status="stopped"
    is_running "$d/vm.pid" && status="running"
    host="$(ssh_host_for "$d")"
    port="$( [ -f "$d/port" ] && cat "$d/port" || echo - )"
    ssh_endpoint="$host:$port"
    size="-"
    local ext
    for ext in qcow2 raw; do
      if [ -f "$d/disk.$ext" ]; then
        size="$(du -h "$d/disk.$ext" | cut -f1)"
        break
      fi
    done
    baked="-"
    rev="-"
    if [ -f "$d/meta.json" ] && command -v jq >/dev/null 2>&1; then
      baked="$(jq -r '.baked_at // "-"' "$d/meta.json")"
      baked="${baked:0:10}"
      local r
      r="$(jq -r '.flake_rev // "-"' "$d/meta.json")"
      if [[ "$r" == *-dirty ]]; then
        rev="${r%%-dirty}"; rev="${rev:0:7}*"
      else
        rev="${r:0:8}"
      fi
    fi

    # shellcheck disable=SC2059
    printf "$fmt" "$name" "$status" "$ssh_endpoint" "$size" "$baked" "$rev" "$d"
  done
  [ "$any" -eq 0 ] && echo "No VMs."
  return 0
}

case "${1:-}" in
  up) shift; cmd_up "$@" ;;
  down) shift; cmd_down "$@" ;;
  rm) shift; cmd_rm "$@" ;;
  ssh) shift; cmd_ssh "$@" ;;
  console) shift; cmd_console "$@" ;;
  info) shift; cmd_info "$@" ;;
  list|ls) cmd_list ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown subcommand: $1" >&2; usage >&2; exit 1 ;;
esac
