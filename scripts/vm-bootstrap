#!/usr/bin/env bash
set -euo pipefail

# Runs inside a freshly-booted VM over SSH. Must be idempotent (i.e.,
# re-running this script should be a no-op once the VM has been set up and
# bootstrapped).

log() { echo "[bootstrap] $*"; }

clone_if_missing() {
  local url="$1" dest="$2"
  if [ -d "$dest" ]; then
    log "$dest already exists — skipping"
    return 0
  fi
  log "cloning $url -> $dest"
  git clone "$url" "$dest"
}

clone_if_missing "https://github.com/mjrusso/.emacs.d" "$HOME/.emacs.d"

mkdir -p "$HOME/git/github.com/mjrusso"
clone_if_missing "https://github.com/mjrusso/wingman" "$HOME/git/github.com/mjrusso/wingman"

log "done"
