#!/usr/bin/env bash
set -euo pipefail

# IMPORTANT: This script must be idempotent (i.e., it must be safe to re-run
# multiple times).

log() { echo "[home-bootstrap] $*"; }

log_manual_secret_setup() {
  cat <<'EOF'
[home-bootstrap] Manual secret setup:
[home-bootstrap]
[home-bootstrap]   GitHub authentication and other secrets are deliberately not handled here.
[home-bootstrap]
[home-bootstrap]   For GitHub, authenticate using the gh CLI based on the machine's role:
[home-bootstrap]
[home-bootstrap]   - Primary machine: run `gh auth login` and follow the browser/device flow.
[home-bootstrap]     The OAuth token lands in the OS keyring, and home-manager's programs.gh
[home-bootstrap]     config has already wired the git credential helper.
[home-bootstrap]
[home-bootstrap]   - Ephemeral or agent VM: do not use the `gh auth login` device flow.
[home-bootstrap]     Instead, mint a fine-grained PAT restricted to the exact repos and
[home-bootstrap]     permissions the agent needs, with a short expiry, and pipe it in from
[home-bootstrap]     1Password on the host:
[home-bootstrap]
[home-bootstrap]       op read "op://Private/github-vm-pat-xxx/credential" \
[home-bootstrap]         | vm ssh <name> 'gh auth login --with-token'
[home-bootstrap]
[home-bootstrap]     Adjust the op:// reference to match the vault and item names. This requires
[home-bootstrap]     the 1Password CLI and the 1Password desktop app with CLI integration enabled.
[home-bootstrap]
[home-bootstrap]   Do not forward the host's ssh-agent into an ephemeral or agent VM.
EOF
}

clone_if_missing() {
  local url="$1" dest="$2"
  if [ -d "$dest" ]; then
    log "$dest already exists — skipping"
    return 0
  fi
  log "cloning $url -> $dest"
  git clone "$url" "$dest"
}

warm_emacs() {
  local emacs_dir="$HOME/.emacs.d"
  if [ ! -d "$emacs_dir" ]; then
    log "$emacs_dir does not exist — skipping Emacs warm-up"
    return 0
  fi

  if ! command -v emacs >/dev/null 2>&1; then
    log "emacs is not available — skipping Emacs warm-up"
    return 0
  fi

  if ! command -v emacsclient >/dev/null 2>&1; then
    log "emacsclient is not available — skipping Emacs warm-up"
    return 0
  fi

  local server_name="home-bootstrap-$$"
  log "warming Emacs by starting temporary daemon '$server_name'"
  emacs --daemon="$server_name"

  log "stopping temporary Emacs daemon '$server_name'"
  if ! emacsclient -s "$server_name" -e '(kill-emacs)' >/dev/null; then
    log "failed to stop temporary Emacs daemon '$server_name'"
    pkill -f "emacs.*--daemon=$server_name" 2>/dev/null || true
    return 1
  fi
}

clone_if_missing "https://github.com/mjrusso/.emacs.d" "$HOME/.emacs.d"

mkdir -p "$HOME/git/github.com/mjrusso"

clone_if_missing "https://github.com/mjrusso/wingman" "$HOME/git/github.com/mjrusso/wingman"

warm_emacs

log ""
log ""

log_manual_secret_setup

log ""
log ""

log "Done"
