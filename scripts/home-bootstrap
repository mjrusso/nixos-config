#!/usr/bin/env bash
set -euo pipefail

# IMPORTANT: This script must be idempotent (i.e., it must be safe to re-run
# multiple times).
#
# GitHub authentication, and other secrets, are deliberately not handled here.
#
# For GitHub specifically, either before or after running this script,
# authenticate using the `gh` CLI based on the machine's role:
#
#   - Primary machine (trusted, interactive use): run `gh auth login` and
#     follow the browser/device flow. The OAuth token lands in the OS keyring,
#     and home-manager's `programs.gh` has already wired the git credential
#     helper, so HTTPS pushes/pulls just work.
#
#   - Ephemeral or "agent" VM (e.g. running coding agents with
#     `--dangerously-skip-permissions` or similar flags that bypass
#     permissions): do *NOT* use the `gh auth login`'s device flow, because
#     the token this grants is far too permissive. Instead, mint a fine-grained
#     PAT restricted to the exact repos and permissions the agent needs, with a
#     short expiry, and pipe it in from 1Password on the host:
#
#       op read "op://Private/github-vm-pat-xxx/credential" \
#         | vm ssh <name> 'gh auth login --with-token'
#
#     Adjust the `op://` reference to match the vault and item names. This
#     requires the 1Password CLI (`op`) and the 1Password desktop app with CLI
#     integration enabled (Settings → Developer → "Integrate with 1Password
#     CLI").
#
# On a related note, do not forward the host's ssh-agent into an ephemeral/
# agent VM.

log() { echo "[home-bootstrap] $*"; }

clone_if_missing() {
  local url="$1" dest="$2"
  if [ -d "$dest" ]; then
    log "$dest already exists — skipping"
    return 0
  fi
  log "cloning $url -> $dest"
  git clone "$url" "$dest"
}

warm_emacs() {
  local emacs_dir="$HOME/.emacs.d"
  if [ ! -d "$emacs_dir" ]; then
    log "$emacs_dir does not exist — skipping Emacs warm-up"
    return 0
  fi

  if ! command -v emacs >/dev/null 2>&1; then
    log "emacs is not available — skipping Emacs warm-up"
    return 0
  fi

  if ! command -v emacsclient >/dev/null 2>&1; then
    log "emacsclient is not available — skipping Emacs warm-up"
    return 0
  fi

  local server_name="home-bootstrap-$$"
  log "warming Emacs by starting temporary daemon '$server_name'"
  emacs --daemon="$server_name"

  log "stopping temporary Emacs daemon '$server_name'"
  if ! emacsclient -s "$server_name" -e '(kill-emacs)' >/dev/null; then
    log "failed to stop temporary Emacs daemon '$server_name'"
    pkill -f "emacs.*--daemon=$server_name" 2>/dev/null || true
    return 1
  fi
}

clone_if_missing "https://github.com/mjrusso/.emacs.d" "$HOME/.emacs.d"

mkdir -p "$HOME/git/github.com/mjrusso"

clone_if_missing "https://github.com/mjrusso/wingman" "$HOME/git/github.com/mjrusso/wingman"

warm_emacs

log "done"
